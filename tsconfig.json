{
  "extends": "@vue/tsconfig/tsconfig.web.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "target": "ESNext",
    "lib": ["DOM","ESNext"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "files": ["auto-imports.d.ts", "components.d.ts", "env.d.ts"],
  "references": [
    {
      "path": "./tsconfig.config.json"
    }
  ]
}
